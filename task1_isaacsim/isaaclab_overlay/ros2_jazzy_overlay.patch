diff --git a/docker/.env.base b/docker/.env.base
index 0cc9ff09c0..33318f9c4d 100644
--- a/docker/.env.base
+++ b/docker/.env.base
@@ -8,7 +8,7 @@ ACCEPT_EULA=Y
 ISAACSIM_BASE_IMAGE=nvcr.io/nvidia/isaac-sim
 # NVIDIA Isaac Sim version to use (e.g. 6.0.0-dev2)
 # TODO(AntoineRichard): Revert to stable 6.0.0 tag once it ships on NGC
-ISAACSIM_VERSION=6.0.0-dev2
+ISAACSIM_VERSION=6.0.0
 # Derived from the default path in the NVIDIA provided Isaac Sim container
 DOCKER_ISAACSIM_ROOT_PATH=/isaac-sim
 # The Isaac Lab path in the container
diff --git a/docker/docker-compose.yaml b/docker/docker-compose.yaml
index b259e0fd39..1342aaa90b 100644
--- a/docker/docker-compose.yaml
+++ b/docker/docker-compose.yaml
@@ -72,6 +72,9 @@ x-default-isaac-lab-volumes: &default-isaac-lab-volumes
   - type: bind
     source: .isaac-lab-docker-history
     target: ${DOCKER_USER_HOME}/.bash_history
+  - type: bind
+    source: __EBIM_CHALLENGE_ROOT__
+    target: /workspace/EBiM_Challenge
 
 x-default-isaac-lab-environment: &default-isaac-lab-environment
   - ISAACSIM_PATH=${DOCKER_ISAACLAB_PATH}/_isaac_sim
@@ -138,6 +141,35 @@ services:
     stdin_open: true
     tty: true
 
+  # This service adds a ROS2 Jazzy
+  # installation on top of the base image
+  isaac-lab-ros2_jazzy:
+    profiles: [ "ros2_jazzy" ]
+    env_file:
+      - .env.base
+      - .env.ros2_jazzy
+    build:
+      context: ../
+      dockerfile: docker/Dockerfile.ros2_jazzy
+      args:
+        # ROS2_APT_PACKAGE will default to NONE. This is to
+        # avoid a warning message when building only the base profile
+        # with the .env.base file
+        - ROS2_APT_PACKAGE=${ROS2_APT_PACKAGE:-NONE}
+        # Make sure that the correct Docker Name Suffix is being passed to the dockerfile, to know which base image to
+        # start from.
+        - DOCKER_NAME_SUFFIX=${DOCKER_NAME_SUFFIX-}
+    image: isaac-lab-ros2_jazzy${DOCKER_NAME_SUFFIX-}
+    container_name: isaac-lab-ros2_jazzy${DOCKER_NAME_SUFFIX-}
+    environment: *default-isaac-lab-environment
+    volumes: *default-isaac-lab-volumes
+    network_mode: host
+    deploy: *default-isaac-lab-deploy
+    # This is the entrypoint for the container
+    entrypoint: bash
+    stdin_open: true
+    tty: true
+
 volumes:
   # isaac-sim
   isaac-cache-kit:
diff --git a/docker/utils/x11_utils.py b/docker/utils/x11_utils.py
index 4d7d0e3639..f2f1b494c0 100644
--- a/docker/utils/x11_utils.py
+++ b/docker/utils/x11_utils.py
@@ -48,7 +48,14 @@ def configure_x11(statefile: StateFile) -> dict[str, str]:
     # load the value of the temporary xauth file
     tmp_xauth_value = statefile.get_variable("__ISAACLAB_TMP_XAUTH")
 
-    if tmp_xauth_value is None or not Path(tmp_xauth_value).exists():
+    # treat a missing or inaccessible cached path (e.g. a stale tmp dir created by another
+    # user) as non-existent so a fresh .xauth file is created instead of crashing
+    try:
+        tmp_xauth_exists = tmp_xauth_value is not None and Path(tmp_xauth_value).exists()
+    except OSError:
+        tmp_xauth_exists = False
+
+    if not tmp_xauth_exists:
         # create a temporary directory to store the .xauth file
         tmp_dir = subprocess.run(["mktemp", "-d"], capture_output=True, text=True, check=True).stdout.strip()
         # create the .xauth file
diff --git a/docker/x11.yaml b/docker/x11.yaml
index bd9b22f16b..19e769330e 100644
--- a/docker/x11.yaml
+++ b/docker/x11.yaml
@@ -39,3 +39,22 @@ services:
       source: /etc/localtime
       target: /etc/localtime
       read_only: true
+
+  isaac-lab-ros2_jazzy:
+    environment:
+      - DISPLAY
+      - TERM
+      - QT_X11_NO_MITSHM=1
+      - XAUTHORITY=${__ISAACLAB_TMP_XAUTH}
+    volumes:
+    - type: bind
