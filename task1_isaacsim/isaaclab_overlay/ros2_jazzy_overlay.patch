+      target: ${__ISAACLAB_TMP_DIR}
+    - type: bind
+      source: /tmp/.X11-unix
+      target: /tmp/.X11-unix
+    - type: bind
+      source: /etc/localtime
+      target: /etc/localtime
+      read_only: true
+
