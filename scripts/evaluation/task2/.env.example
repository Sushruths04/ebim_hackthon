# Copy to `.env` (setup.sh does this) and adjust as needed.
# run.sh / docker compose load this file automatically.

# Host root for persistent volumes (matches docker/.env.base convention).
# Artifacts land in ${ISAAC_DOCKER_ROOT}/eval-task2/evaluate/.
ISAAC_DOCKER_ROOT=${HOME}/docker/ebim-challenge

# Match the host user so artifact files are owned by current user, not root.
# setup.sh fills these with `id -u` / `id -g`.
HOST_UID=1000
HOST_GID=1000
